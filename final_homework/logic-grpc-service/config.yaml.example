oss:
  endpoint: "${OSS_ENDPOINT}"
  access_key_id: "${OSS_ACCESS_KEY_ID}"
  access_key_secret: "${OSS_ACCESS_KEY_SECRET}"
  bucket_name: "${OSS_BUCKET_NAME}"

mysql:
  host: "${MYSQL_HOST}"
  port: "${MYSQL_PORT}"
  user: "${MYSQL_USER}"
  password: "${MYSQL_PASSWORD}"
  database: "${MYSQL_DATABASE}"